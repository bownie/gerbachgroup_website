---
// src/components/Header.astro
interface Props {
  activePage?: string;
}
const { activePage } = Astro.props;

const navLinks = [
  { href: '/our-story', label: 'Our Story' },
  { href: '/our-people', label: 'Leadership' },
  { href: '/global-reach', label: 'Global Reach' },
  { href: '/advanced-systems', label: 'Advanced Systems' },
  { href: '/our-promise', label: 'Our Promise' },
  { href: '/our-guarantee', label: 'Our Guarantee' },
];
---
<header class="header">
  <div class="container">
    <div class="logo">
      <a href="/">
        <span class="logo-main">GERBACH</span>
        <span class="logo-sub">Logistics &amp; Expedition Inc.</span>
      </a>
    </div>
    <nav class="nav">
      <ul>
        {navLinks.map(link => (
          <li>
            <a href={link.href} class={activePage === link.href ? 'active' : ''}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    background: var(--white);
    border-bottom: 3px solid var(--red);
    padding: 1.2rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header .container { display: flex; justify-content: space-between; align-items: center; }
  .logo a { display: flex; flex-direction: column; line-height: 1; text-decoration: none; }
  .logo-main {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2rem;
    letter-spacing: 0.08em;
    color: var(--black);
  }
  .logo-sub {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--grey);
  }
  .nav ul { display: flex; gap: 2rem; list-style: none; padding: 0; margin: 0; }
  .nav a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dark);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav a:hover,
  .nav a.active { color: var(--red); }

  @media (max-width: 900px) {
    .nav { display: none; }
  }
</style>
