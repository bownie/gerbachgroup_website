---
import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

// src/pages/advanced-systems.astro
const title = "Advanced Systems — Gerbach Logistics and Expedition Inc";
const description = "TrolleyTrack, ChainLink, and DollyAI — Gerbach's proprietary technology suite powering global logistics excellence.";

const systems = [
  {
    id: "trolleytrack",
    name: "TrolleyTrack",
    subtitle: "Warehouse Management System",
    tagline: "More Than Management — Complete Warehouse Intelligence",
    intro: "TrolleyTrack transforms warehouse operations from reactive management to proactive optimisation. Built from decades of real-world logistics experience, this comprehensive system handles everything from inventory tracking to labour optimisation with unprecedented precision and flexibility.",
    deployments: [
      {
        type: "Cloud-Hosted",
        points: [
          "Immediate deployment with zero infrastructure investment — operational within days, not months",
          "Automatic updates ensure you always have the latest features and security patches",
          "Elastic scaling handles peak seasons without performance degradation",
          "99.99% uptime with global redundancy — your operations never sleep",
          "Secure encrypted access from anywhere in the world"
        ]
      },
      {
        type: "On-Premises",
        points: [
          "Complete control over your data with customisable security protocols",
          "Direct integration with existing enterprise systems without internet dependency",
          "Customisable workflows and reporting to match your exact operational needs",
          "Consistent performance regardless of internet connectivity",
          "Ultimate data sovereignty for organisations with strict compliance requirements"
        ]
      }
    ],
    capabilities: [
      "Real-time inventory tracking with RFID and barcode integration across multiple locations",
      "Advanced pick path optimisation — reduces warehouse travel time by up to 35%",
      "Intelligent space utilisation algorithms that maximise storage efficiency",
      "Comprehensive labour management with productivity tracking and task assignment",
      "Automated reorder alerts with supplier integration for seamless replenishment",
      "Detailed analytics with customisable dashboards for every level of management"
    ]
  },
  {
    id: "chainlink",
    name: "ChainLink",
    subtitle: "Supply Chain Management Solution",
    tagline: "Orchestrating Complexity Into Simplicity",
    intro: "ChainLink doesn't just manage your supply chain — it anticipates its needs. This powerful platform provides end-to-end visibility and control across every supplier, every shipment, and every delivery, transforming supply chain complexity into competitive advantage.",
    deployments: [
      {
        type: "Cloud-Hosted",
        points: [
          "Rapid deployment across multiple locations with automatic synchronisation",
          "Scalable processing power handles supply chain complexity without hardware upgrades",
          "Automatic backups and disaster recovery protect against data loss",
          "Seamless integration with external suppliers via secure API connections",
          "Global accessibility for multinational operations"
        ]
      },
      {
        type: "On-Premises",
        points: [
          "Complete control over sensitive supply chain data with customisable security",
          "Direct integration with legacy systems without external dependencies",
          "Ability to maintain operations during internet outages",
          "Customisable data retention and compliance controls",
          "Dedicated processing power ensures consistent peak performance"
        ]
      }
    ],
    capabilities: [
      "Multi-tier supplier management with performance tracking and automated vendor scorecards",
      "Demand forecasting using advanced algorithms analysing historical data, seasonal trends, and market indicators",
      "Real-time shipment tracking across all transport modes with exception management",
      "Purchase order automation with approval workflows and budget controls",
      "Risk management tools that identify potential disruptions before they impact operations",
      "Comprehensive reporting suite with customisable KPIs and executive dashboards"
    ]
  },
  {
    id: "dollyai",
    name: "DollyAI",
    subtitle: "Intelligent Logistics Platform",
    tagline: "Where Artificial Intelligence Meets Human Insight",
    intro: "DollyAI represents the next evolution in supply chain technology, combining machine learning, predictive analytics, and natural language processing to create a system that doesn't just respond to logistics challenges — it prevents them. This revolutionary platform learns from every transaction, every route, and every decision to continuously optimise performance across your entire logistics ecosystem.",
    deployments: [
      {
        type: "Predictive Intelligence",
        points: [
          "Advanced machine learning analyses millions of data points to predict demand fluctuations",
          "Identifies potential disruptions and recommends optimal routing decisions",
          "Doesn't just tell you what happened — shows you what's going to happen and what to do about it"
        ]
      },
      {
        type: "Autonomous Optimisation",
        points: [
          "Continuous route optimisation adapting to real-time weather, traffic, and capacity constraints",
          "Intelligent inventory positioning that anticipates demand and pre-positions stock",
          "Automated carrier selection balancing cost, speed, and reliability for every shipment"
        ]
      }
    ],
    capabilities: [
      "Natural language interface — query your entire logistics operation in plain English",
      "Anomaly detection that identifies irregularities before they become problems",
      "Dynamic pricing optimisation that maximises margins while maintaining competitiveness",
      "Automated exception management that resolves routine issues without human intervention",
      "Continuous learning from every transaction to improve future performance",
      "Integration with TrolleyTrack and ChainLink for complete operational intelligence"
    ]
  }
];
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

<TopBar />
<Header activePage="/our-guarantee" />

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-bg">
    <img src="/images/aerial-background-slice.jpg" alt="Advanced logistics systems" />
    <div class="page-hero-overlay"></div>
  </div>
  <div class="container page-hero-content">
    <p class="eyebrow">Gerbach Logistics &amp; Expedition</p>
    <h1>Advanced Systems</h1>
    <p class="subhead">Powering Your Global Excellence</p>
  </div>
</section>

<!-- Intro -->
<section class="intro-section">
  <div class="container">
    <div class="intro-inner">
      <p class="lead">At Gerbach, we believe that exceptional logistics begins with exceptional technology. Our integrated suite of proprietary systems doesn't just manage inventory and track shipments — it creates an intelligent ecosystem that learns, adapts, and optimises with every transaction.</p>
      <div class="system-nav">
        <a href="#trolleytrack">TrolleyTrack</a>
        <a href="#chainlink">ChainLink</a>
        <a href="#dollyai">DollyAI</a>
      </div>
    </div>
  </div>
</section>

<!-- Systems -->
{systems.map(system => (
  <section class="system-section" id={system.id}>
    <div class="container">
      <div class="system-header">
        <div class="system-title-block">
          <h2 class="system-name">{system.name}</h2>
          <p class="system-subtitle">{system.subtitle}</p>
        </div>
        <p class="system-tagline">{system.tagline}</p>
      </div>

      <p class="system-intro">{system.intro}</p>

      <div class="deployment-grid">
        {system.deployments.map(dep => (
          <div class="deployment-card">
            <h3>{dep.type}</h3>
            <ul>
              {dep.points.map(point => (
                <li>{point}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="capabilities-block">
        <h3>Core Capabilities</h3>
        <ul class="capabilities-list">
          {system.capabilities.map(cap => (
            <li>{cap}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>
))}

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <h2>Ready to transform your logistics?</h2>
    <p>Our technology team is ready to walk you through a demonstration of any of our systems and build a solution tailored to your operation.</p>
    <a href="mailto:reachus@gerbachgroup.com" class="btn-primary">Get in touch →</a>
  </div>
</section>

<Footer />

</body>
</html>
