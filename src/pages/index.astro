---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const homePath = getRelativeLocaleUrl(locale, "");
// src/pages/index.astro
// Gerbach Logistics and Expedition Inc — fictional company site
const title = "The Future, Delivered — Gerbach Logistics and Expedition Inc";
const description = "Bringing The World Closer Together. Global transportation and expediting services from Cicero, IL.";
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://gerbachgroup.com/" />
  <meta property="og:site_name" content="Gerbach Logistics and Expedition Inc" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div class="container">
    <span class="topbar-left">
      <a href="mailto:reachus@gerbachgroup.com">reachus@gerbachgroup.com</a>
      <span>Phone: +1 4700 555 555</span>
    </span>
    <a class="topbar-cta" href="/contact">Enquire Now</a>
  </div>
</div>

<!-- Header -->
<header class="header">
  <div class="container">
    <div class="logo">
      <a href="/">
        <span class="logo-main">GERBACH</span>
        <span class="logo-sub">Logistics &amp; Expedition Inc.</span>
      </a>
    </div>
    <nav class="nav">
      <ul>
        <li><a href="/our-story">Our Story</a></li>
        <li><a href="/our-people">Leadership</a></li>
        <li><a href="/global-reach">Global Reach</a></li>
        <li><a href="/advanced-systems">Advanced Systems</a></li>
        <li><a href="/our-promise">Our Promise</a></li>
        <li><a href="/our-guarantee">Our Guarantee</a></li>
      </ul>
    </nav>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg">
    <img src="/default-og.jpg" alt="Aerial logistics" />
    <div class="hero-overlay"></div>
  </div>
  <div class="container hero-content">
    <p class="hero-eyebrow">Gerbach Logistics &amp; Expedition</p>
    <h1>The Future,<br/><span>Delivered.</span></h1>
    <p class="hero-tagline">Moving your business forward — one shipment at a time.</p>
    <a href="/our-promise" class="btn-primary">Our Promise</a>
  </div>
</section>

<!-- Services strip -->
<section class="services">
  <div class="container">
    <div class="services-grid">

      <a href="/global-reach" class="service-card">
        <div class="service-icon">🌐</div>
        <h3>Global Reach</h3>
        <h4>Where the World Meets, Gerbach Delivers</h4>
        <p>From our founding in Cicero, IL to every continent on earth — distance is never a barrier to your ambitions.</p>
        <span class="read-more">Read More →</span>
      </a>

      <a href="/advanced-systems" class="service-card">
        <div class="service-icon">⚙️</div>
        <h3>Advanced Systems</h3>
        <h4>Powering Your Global Excellence</h4>
        <p>AI-powered routing, real-time tracking, and predictive delivery windows — technology that thinks ahead.</p>
        <span class="read-more">Read More →</span>
      </a>

      <a href="/our-promise" class="service-card">
        <div class="service-icon">✦</div>
        <h3>Our Promise</h3>
        <h4>Moving Your Business Forward</h4>
        <p>Every shipment treated with the precision of a Swiss timepiece and the care of a family heirloom.</p>
        <span class="read-more">Read More →</span>
      </a>

    </div>
  </div>
</section>

<!-- Main content -->
<section class="content-section">
  <div class="container content-grid">
    <div class="content-image">
      <img src="/images/aerial-background-slice.jpg" alt="Gerbach operations" />
    </div>
    <div class="content-body">
      <h2>Our Promise</h2>
      <h3>Moving Your Business Forward</h3>
      <p>Experience logistics redefined through superior systems, seamless processes, and unmatched global reach. At Gerbach Logistics &amp; Expeditions, we don't just move packages — we move your business forward.</p>
      <p>Every shipment is treated with the precision of a Swiss timepiece and the care of a family heirloom, because we know that behind every tracking number lies someone's trust, dreams, and success.</p>

      <h3>Global Reach, Local Care</h3>
      <p>From bustling metropolises to the most remote corners of the earth, our extensive network spans every continent and connects every possibility. Your packages don't just travel — they arrive with purpose.</p>

      <h3>Superior Systems That Think Ahead</h3>
      <p>Our cutting-edge technology doesn't just track your shipments — it anticipates their needs. Advanced routing algorithms, AI-powered optimisation, and real-time intelligence ensure your packages take the smartest path possible.</p>

      <a href="/our-promise" class="btn-secondary">Read the full promise →</a>
    </div>
  </div>
</section>

<!-- Stats bar -->
<section class="stats-bar">
  <div class="container stats-grid">
    <div class="stat">
      <span class="stat-number">90+</span>
      <span class="stat-label">Years in business</span>
    </div>
    <div class="stat">
      <span class="stat-number">6</span>
      <span class="stat-label">Continents served</span>
    </div>
    <div class="stat">
      <span class="stat-number">24/7</span>
      <span class="stat-label">Customer support</span>
    </div>
    <div class="stat">
      <span class="stat-number">100%</span>
      <span class="stat-label">Insured shipments</span>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container footer-grid">

    <div class="footer-col">
      <h5>Contact Info</h5>
      <address>
        4629 W Cermak Rd<br />
        Cicero, IL 60804<br />
        <a href="tel:+14700555555">+1 4700 555 555</a><br />
        <a href="mailto:reachus@gerbachgroup.com">reachus@gerbachgroup.com</a>
      </address>
    </div>

    <div class="footer-col">
      <h5>Navigation</h5>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/global-reach">Global Reach</a></li>
        <li><a href="/advanced-systems">Advanced Systems</a></li>
        <li><a href="/our-guarantee">Our Guarantee</a></li>
        <li><a href="/our-people">Leadership Team</a></li>
        <li><a href="/our-promise">Our Promise</a></li>
        <li><a href="/our-story">Our Story</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5>About Us</h5>
      <p>Gerbach provides global transportation and expediting services for businesses of all sizes. A family-owned company from Cicero, IL with presence in the US, Europe, India, Africa, and Australasia.</p>
    </div>

  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>© {new Date().getFullYear()} Gerbach Logistics and Expedition Inc. All Rights Reserved.</p>
    </div>
  </div>
</footer>

</body>
</html>

<style>
  /* ─── Reset & Base ─────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --red: #c8102e;
    --red-dark: #9e0c24;
    --black: #0d0d0d;
    --dark: #1a1a1a;
    --mid: #2e2e2e;
    --grey: #6b6b6b;
    --light: #f4f4f2;
    --white: #ffffff;
    --font-display: 'Barlow Condensed', sans-serif;
    --font-body: 'Barlow', sans-serif;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--white);
    color: var(--black);
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }
  address { font-style: normal; }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ─── Top Bar ──────────────────────────────────────────────── */
  .topbar {
    background: var(--black);
    color: var(--light);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    padding: 0.5rem 0;
  }

  .topbar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .topbar-left {
    display: flex;
    gap: 2rem;
  }

  .topbar-left a { color: #aaa; }
  .topbar-left a:hover { color: var(--white); }

  .topbar-cta {
    background: var(--red);
    color: var(--white);
    padding: 0.3rem 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s;
  }

  .topbar-cta:hover { background: var(--red-dark); }

  /* ─── Header ───────────────────────────────────────────────── */
  .header {
    background: var(--white);
    border-bottom: 3px solid var(--red);
    padding: 1.2rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo a {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .logo-main {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2rem;
    letter-spacing: 0.08em;
    color: var(--black);
  }

  .logo-sub {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--grey);
  }

  .nav ul {
    display: flex;
    gap: 2rem;
  }

  .nav a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dark);
    transition: color 0.2s;
  }

  .nav a:hover { color: var(--red); }

  /* ─── Hero ─────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    color: var(--white);
    max-width: 650px;
  }

  .hero-eyebrow {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1rem;
  }

  .hero-content h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
  }

  .hero-content h1 span { color: var(--red); }

  .hero-tagline {
    font-size: 1.1rem;
    font-weight: 300;
    color: #ccc;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--red);
    color: var(--white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.85rem 2.2rem;
    transition: background 0.2s, transform 0.1s;
  }

  .btn-primary:hover { background: var(--red-dark); transform: translateY(-1px); }

  /* ─── Services ─────────────────────────────────────────────── */
  .services {
    background: var(--dark);
    padding: 4rem 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .service-card {
    display: block;
    background: var(--mid);
    padding: 2.5rem 2rem;
    transition: background 0.2s;
    border-top: 3px solid transparent;
  }

  .service-card:hover {
    background: #3a3a3a;
    border-top-color: var(--red);
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 0.3rem;
  }

  .service-card h4 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1rem;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .service-card p {
    font-size: 0.9rem;
    color: #999;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .read-more {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--red);
    text-transform: uppercase;
  }

  /* ─── Content Section ──────────────────────────────────────── */
  .content-section {
    padding: 6rem 0;
    background: var(--white);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .content-image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .content-body h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2.5rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--black);
    margin-bottom: 0.5rem;
  }

  .content-body h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--red);
    letter-spacing: 0.03em;
    margin: 1.5rem 0 0.5rem;
  }

  .content-body p {
    font-size: 1rem;
    color: #444;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .btn-secondary {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--red);
    border-bottom: 2px solid var(--red);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-secondary:hover { color: var(--red-dark); border-color: var(--red-dark); }

  /* ─── Stats ────────────────────────────────────────────────── */
  .stats-bar {
    background: var(--red);
    padding: 3rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 3rem;
    color: var(--white);
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin-top: 0.4rem;
  }

  /* ─── Footer ───────────────────────────────────────────────── */
  .footer {
    background: var(--black);
    color: var(--light);
    padding: 4rem 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1.5fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #2a2a2a;
  }

  .footer-col h5 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1.2rem;
  }

  .footer-col address,
  .footer-col p {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.8;
  }

  .footer-col a { color: #888; transition: color 0.2s; }
  .footer-col a:hover { color: var(--white); }

  .footer-col ul li {
    margin-bottom: 0.5rem;
  }

  .footer-col ul a {
    font-size: 0.9rem;
    color: #888;
  }

  .footer-bottom {
    padding: 1.2rem 0;
  }

  .footer-bottom p {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: #444;
    text-align: center;
  }

  /* ─── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .services-grid { grid-template-columns: 1fr; gap: 2px; }
    .content-grid { grid-template-columns: 1fr; gap: 2rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .nav { display: none; }
  }

  @media (max-width: 600px) {
    .hero { height: 480px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .topbar-left span { display: none; }
  }
</style>