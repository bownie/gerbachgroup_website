---

import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

// src/pages/our-guarantee.astro
const title = "Our Guarantee — Gerbach Logistics and Expedition Inc";
const description = "Where trust meets performance. Every Gerbach promise is backed by the full weight of our reputation and nearly a century of results.";

const personalGuarantees = [
  {
    name: "Safe Delivery Guarantee",
    detail: "Every package entrusted to Gerbach is covered by our comprehensive protection plan from pickup to final delivery. If your shipment is damaged, lost, or stolen while in our care, we don't just apologise — we make it right immediately. Full replacement value coverage with no deductibles, no hidden exclusions, and no complicated claims process."
  },
  {
    name: "On-Time Delivery Promise",
    detail: "We guarantee delivery within our promised timeframe, or the shipping cost is on us. No exceptions, no excuses. Our advanced tracking systems and route optimisation ensure over 99.7% on-time performance, but when the unexpected happens, we take full responsibility for the delay and the cost."
  },
  {
    name: "White Glove Care Standard",
    detail: "Your packages receive the same careful handling we'd give our own family's shipments. Temperature-sensitive items stay within optimal ranges, fragile goods receive specialised packaging and handling, and high-value shipments travel with enhanced security protocols. Every Gerbach team member understands that behind every tracking number is someone's trust."
  },
  {
    name: "Real-Time Transparency",
    detail: "You'll never wonder where your package is or when it will arrive. Our advanced tracking system provides real-time updates, predictive delivery windows, and proactive notifications about any changes to your delivery schedule. If we know it, you know it — guaranteed."
  },
  {
    name: "Hassle-Free Claims Resolution",
    detail: "In the rare event something goes wrong, our claims process is designed around your convenience, not our bureaucracy. Single point of contact, 24-hour initial response, and resolution within 5 business days. No endless phone transfers, no form letters, no runaround — just straightforward solutions from people who care."
  }
];

const businessGuarantees = [
  {
    name: "Service Level Agreements That Matter",
    detail: "Our business guarantee begins with clearly defined, measurable service levels aligned to your operational needs. We don't just promise these standards — we guarantee them with financial penalties if we fall short."
  },
  {
    name: "Supply Chain Continuity Assurance",
    detail: "Our redundant systems, alternative route planning, and backup facility network ensure that even in extraordinary circumstances, your shipments keep moving. We guarantee supply chain continuity or we absorb the costs of expedited alternative solutions."
  },
  {
    name: "Data Security and Privacy Protection",
    detail: "Your business information and shipment data are protected by military-grade security protocols. We guarantee complete confidentiality of your supply chain information, with legal liability protection and immediate notification of any security incidents."
  },
  {
    name: "Scalability Without Compromise",
    detail: "We commit to maintaining the same service levels whether you ship 10 packages a month or 10,000. No hidden capacity limits, no service degradation during peak periods, and no renegotiation of core service standards as volumes increase."
  },
  {
    name: "Financial Stability Assurance",
    detail: "With nearly 100 years of profitable operations and conservative financial management, we guarantee the stability and reliability your supply chain demands. Gerbach's financial strength is your guarantee of service continuity."
  },
  {
    name: "Custom Solution Development",
    detail: "Every business has unique logistics requirements, and we guarantee solutions tailored to your specific needs. Our guarantee includes the development of systems and processes that fit your business — not forcing your business to fit our systems."
  }
];

const universalGuarantees = [
  {
    name: "Environmental Responsibility",
    detail: "We guarantee your shipments travel through the most environmentally responsible routes and methods available. Our carbon offset programmes, sustainable packaging initiatives, and fuel-efficient networks ensure your logistics footprint aligns with your environmental values."
  },
  {
    name: "Ethical Business Practices",
    detail: "Every aspect of our operation adheres to the highest ethical standards. We guarantee fair labour practices throughout our network, transparent pricing with no hidden fees, and honest communication about capabilities and limitations."
  },
  {
    name: "Continuous Improvement Promise",
    detail: "We guarantee our service will improve year over year through technology investments, process optimisation, and team development. Your logistics experience with Gerbach will be better next year than it is today."
  }
];
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body>


<TopBar />
<Header activePage="/our-guarantee" />

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-bg">
    <img src="/images/new-york-skyline-slice.jpg" alt="Gerbach guarantee" />
    <div class="page-hero-overlay"></div>
  </div>
  <div class="container page-hero-content">
    <p class="eyebrow">Gerbach Logistics &amp; Expedition</p>
    <h1>Our Guarantee</h1>
    <p class="subhead">Where Trust Meets Performance</p>
  </div>
</section>

<!-- Opening -->
<section class="opening-section">
  <div class="container">
    <div class="opening-inner">
      <p class="opening-text">For nearly a century, the Gerbach name has stood for one unwavering principle: your trust is our most valuable asset.</p>
      <p class="opening-sub">From Heinrich and Wilhelm's handshake agreements in their Cicero garage to today's global operations, every promise we make is backed by the full weight of our reputation and resources. We don't just guarantee delivery — we guarantee peace of mind.</p>
    </div>
  </div>
</section>

<!-- Personal guarantees -->
<section class="guarantee-section">
  <div class="container">
    <div class="section-label">
      <span>Your Package, Our Personal Commitment</span>
    </div>
    <div class="guarantee-grid">
      {personalGuarantees.map(g => (
        <div class="guarantee-card">
          <div class="guarantee-icon">✓</div>
          <div class="guarantee-body">
            <h3>{g.name}</h3>
            <p>{g.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Business guarantees -->
<section class="guarantee-section alt">
  <div class="container">
    <div class="section-label">
      <span>For Business Partners — Your Success, Our Commitment</span>
    </div>
    <div class="guarantee-grid two-col">
      {businessGuarantees.map(g => (
        <div class="guarantee-card">
          <div class="guarantee-icon">✓</div>
          <div class="guarantee-body">
            <h3>{g.name}</h3>
            <p>{g.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Universal guarantees -->
<section class="guarantee-section">
  <div class="container">
    <div class="section-label">
      <span>Universal Guarantees — Every Customer, Every Shipment</span>
    </div>
    <div class="guarantee-grid">
      {universalGuarantees.map(g => (
        <div class="guarantee-card">
          <div class="guarantee-icon">✓</div>
          <div class="guarantee-body">
            <h3>{g.name}</h3>
            <p>{g.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <h2>Ready to experience the Gerbach guarantee?</h2>
    <p>Contact us today and let us show you what a century of kept promises looks like in practice.</p>
    <a href="mailto:reachus@gerbachgroup.com" class="btn-primary">Get in touch →</a>
  </div>
</section>

<Footer />

</body>
</html>