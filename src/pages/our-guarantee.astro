---
// src/pages/our-guarantee.astro
const title = "Our Guarantee — Gerbach Logistics and Expedition Inc";
const description = "Where trust meets performance. Every Gerbach promise is backed by the full weight of our reputation and nearly a century of results.";

const personalGuarantees = [
  {
    name: "Safe Delivery Guarantee",
    detail: "Every package entrusted to Gerbach is covered by our comprehensive protection plan from pickup to final delivery. If your shipment is damaged, lost, or stolen while in our care, we don't just apologise — we make it right immediately. Full replacement value coverage with no deductibles, no hidden exclusions, and no complicated claims process."
  },
  {
    name: "On-Time Delivery Promise",
    detail: "We guarantee delivery within our promised timeframe, or the shipping cost is on us. No exceptions, no excuses. Our advanced tracking systems and route optimisation ensure over 99.7% on-time performance, but when the unexpected happens, we take full responsibility for the delay and the cost."
  },
  {
    name: "White Glove Care Standard",
    detail: "Your packages receive the same careful handling we'd give our own family's shipments. Temperature-sensitive items stay within optimal ranges, fragile goods receive specialised packaging and handling, and high-value shipments travel with enhanced security protocols. Every Gerbach team member understands that behind every tracking number is someone's trust."
  },
  {
    name: "Real-Time Transparency",
    detail: "You'll never wonder where your package is or when it will arrive. Our advanced tracking system provides real-time updates, predictive delivery windows, and proactive notifications about any changes to your delivery schedule. If we know it, you know it — guaranteed."
  },
  {
    name: "Hassle-Free Claims Resolution",
    detail: "In the rare event something goes wrong, our claims process is designed around your convenience, not our bureaucracy. Single point of contact, 24-hour initial response, and resolution within 5 business days. No endless phone transfers, no form letters, no runaround — just straightforward solutions from people who care."
  }
];

const businessGuarantees = [
  {
    name: "Service Level Agreements That Matter",
    detail: "Our business guarantee begins with clearly defined, measurable service levels aligned to your operational needs. We don't just promise these standards — we guarantee them with financial penalties if we fall short."
  },
  {
    name: "Supply Chain Continuity Assurance",
    detail: "Our redundant systems, alternative route planning, and backup facility network ensure that even in extraordinary circumstances, your shipments keep moving. We guarantee supply chain continuity or we absorb the costs of expedited alternative solutions."
  },
  {
    name: "Data Security and Privacy Protection",
    detail: "Your business information and shipment data are protected by military-grade security protocols. We guarantee complete confidentiality of your supply chain information, with legal liability protection and immediate notification of any security incidents."
  },
  {
    name: "Scalability Without Compromise",
    detail: "We commit to maintaining the same service levels whether you ship 10 packages a month or 10,000. No hidden capacity limits, no service degradation during peak periods, and no renegotiation of core service standards as volumes increase."
  },
  {
    name: "Financial Stability Assurance",
    detail: "With nearly 100 years of profitable operations and conservative financial management, we guarantee the stability and reliability your supply chain demands. Gerbach's financial strength is your guarantee of service continuity."
  },
  {
    name: "Custom Solution Development",
    detail: "Every business has unique logistics requirements, and we guarantee solutions tailored to your specific needs. Our guarantee includes the development of systems and processes that fit your business — not forcing your business to fit our systems."
  }
];

const universalGuarantees = [
  {
    name: "Environmental Responsibility",
    detail: "We guarantee your shipments travel through the most environmentally responsible routes and methods available. Our carbon offset programmes, sustainable packaging initiatives, and fuel-efficient networks ensure your logistics footprint aligns with your environmental values."
  },
  {
    name: "Ethical Business Practices",
    detail: "Every aspect of our operation adheres to the highest ethical standards. We guarantee fair labour practices throughout our network, transparent pricing with no hidden fees, and honest communication about capabilities and limitations."
  },
  {
    name: "Continuous Improvement Promise",
    detail: "We guarantee our service will improve year over year through technology investments, process optimisation, and team development. Your logistics experience with Gerbach will be better next year than it is today."
  }
];
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div class="container">
    <span class="topbar-left">
      <a href="mailto:reachus@gerbachgroup.com">reachus@gerbachgroup.com</a>
      <span>Phone: +1 4700 555 555</span>
    </span>
    <a class="topbar-cta" href="/contact">Enquire Now</a>
  </div>
</div>

<!-- Header -->
<header class="header">
  <div class="container">
    <div class="logo">
      <a href="/">
        <span class="logo-main">GERBACH</span>
        <span class="logo-sub">Logistics &amp; Expedition Inc.</span>
      </a>
    </div>
    <nav class="nav">
      <ul>
        <li><a href="/our-story">Our Story</a></li>
        <li><a href="/our-people">Leadership</a></li>
        <li><a href="/global-reach">Global Reach</a></li>
        <li><a href="/advanced-systems">Advanced Systems</a></li>
        <li><a href="/our-promise">Our Promise</a></li>
        <li><a href="/our-guarantee" class="active">Our Guarantee</a></li>
      </ul>
    </nav>
  </div>
</header>

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-bg">
    <img src="/images/new-york-skyline-slice-1.jpg" alt="Gerbach guarantee" />
    <div class="page-hero-overlay"></div>
  </div>
  <div class="container page-hero-content">
    <p class="eyebrow">Gerbach Logistics &amp; Expedition</p>
    <h1>Our Guarantee</h1>
    <p class="subhead">Where Trust Meets Performance</p>
  </div>
</section>

<!-- Opening -->
<section class="opening-section">
  <div class="container">
    <div class="opening-inner">
      <p class="opening-text">For nearly a century, the Gerbach name has stood for one unwavering principle: your trust is our most valuable asset.</p>
      <p class="opening-sub">From Heinrich and Wilhelm's handshake agreements in their Cicero garage to today's global operations, every promise we make is backed by the full weight of our reputation and resources. We don't just guarantee delivery — we guarantee peace of mind.</p>
    </div>
  </div>
</section>

<!-- Personal guarantees -->
<section class="guarantee-section">
  <div class="container">
    <div class="section-label">
      <span>Your Package, Our Personal Commitment</span>
    </div>
    <div class="guarantee-grid">
      {personalGuarantees.map(g => (
        <div class="guarantee-card">
          <div class="guarantee-icon">✓</div>
          <div class="guarantee-body">
            <h3>{g.name}</h3>
            <p>{g.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Business guarantees -->
<section class="guarantee-section alt">
  <div class="container">
    <div class="section-label">
      <span>For Business Partners — Your Success, Our Commitment</span>
    </div>
    <div class="guarantee-grid two-col">
      {businessGuarantees.map(g => (
        <div class="guarantee-card">
          <div class="guarantee-icon">✓</div>
          <div class="guarantee-body">
            <h3>{g.name}</h3>
            <p>{g.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Universal guarantees -->
<section class="guarantee-section">
  <div class="container">
    <div class="section-label">
      <span>Universal Guarantees — Every Customer, Every Shipment</span>
    </div>
    <div class="guarantee-grid">
      {universalGuarantees.map(g => (
        <div class="guarantee-card">
          <div class="guarantee-icon">✓</div>
          <div class="guarantee-body">
            <h3>{g.name}</h3>
            <p>{g.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <h2>Ready to experience the Gerbach guarantee?</h2>
    <p>Contact us today and let us show you what a century of kept promises looks like in practice.</p>
    <a href="mailto:reachus@gerbachgroup.com" class="btn-primary">Get in touch →</a>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-col">
      <h5>Contact Info</h5>
      <address>
        4629 W Cermak Rd<br />
        Cicero, IL 60804<br />
        <a href="tel:+14700555555">+1 4700 555 555</a><br />
        <a href="mailto:reachus@gerbachgroup.com">reachus@gerbachgroup.com</a>
      </address>
    </div>
    <div class="footer-col">
      <h5>Navigation</h5>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/global-reach">Global Reach</a></li>
        <li><a href="/advanced-systems">Advanced Systems</a></li>
        <li><a href="/our-guarantee">Our Guarantee</a></li>
        <li><a href="/our-people">Leadership Team</a></li>
        <li><a href="/our-promise">Our Promise</a></li>
        <li><a href="/our-story">Our Story</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h5>About Us</h5>
      <p>Gerbach provides global transportation and expediting services for businesses of all sizes. A family-owned company from Cicero, IL with presence in the US, Europe, India, Africa, and Australasia.</p>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>© {new Date().getFullYear()} Gerbach Logistics and Expedition Inc. All Rights Reserved.</p>
    </div>
  </div>
</footer>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --red: #c8102e;
    --red-dark: #9e0c24;
    --black: #0d0d0d;
    --dark: #1a1a1a;
    --mid: #2e2e2e;
    --grey: #6b6b6b;
    --light: #f4f4f2;
    --white: #ffffff;
    --font-display: 'Barlow Condensed', sans-serif;
    --font-body: 'Barlow', sans-serif;
  }

  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: var(--font-body); background: var(--white); color: var(--black); line-height: 1.6; }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }
  address { font-style: normal; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  /* Top bar */
  .topbar { background: var(--black); font-family: var(--font-display); font-size: 0.85rem; letter-spacing: 0.04em; padding: 0.5rem 0; }
  .topbar .container { display: flex; justify-content: space-between; align-items: center; }
  .topbar-left { display: flex; gap: 2rem; color: #aaa; }
  .topbar-left a { color: #aaa; }
  .topbar-left a:hover { color: var(--white); }
  .topbar-cta { background: var(--red); color: var(--white); padding: 0.3rem 1rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }
  .topbar-cta:hover { background: var(--red-dark); }

  /* Header */
  .header { background: var(--white); border-bottom: 3px solid var(--red); padding: 1.2rem 0; position: sticky; top: 0; z-index: 100; }
  .header .container { display: flex; justify-content: space-between; align-items: center; }
  .logo a { display: flex; flex-direction: column; line-height: 1; }
  .logo-main { font-family: var(--font-display); font-weight: 900; font-size: 2rem; letter-spacing: 0.08em; color: var(--black); }
  .logo-sub { font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--grey); }
  .nav ul { display: flex; gap: 2rem; }
  .nav a { font-family: var(--font-display); font-weight: 600; font-size: 0.85rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dark); transition: color 0.2s; }
  .nav a:hover, .nav a.active { color: var(--red); }

  /* Page hero */
  .page-hero { position: relative; height: 380px; overflow: hidden; display: flex; align-items: flex-end; }
  .page-hero-bg { position: absolute; inset: 0; }
  .page-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 60%, transparent 100%); }
  .page-hero-content { position: relative; z-index: 2; color: var(--white); padding-bottom: 3rem; }
  .eyebrow { font-family: var(--font-display); font-weight: 300; font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 0.5rem; }
  .page-hero-content h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(2.5rem, 5vw, 4rem); text-transform: uppercase; letter-spacing: 0.02em; line-height: 1; margin-bottom: 0.5rem; }
  .subhead { font-family: var(--font-display); font-weight: 300; font-size: 1.1rem; color: #ccc; }

  /* Opening */
  .opening-section { background: var(--dark); padding: 4rem 0; }
  .opening-inner { max-width: 820px; }
  .opening-text { font-family: var(--font-display); font-size: 1.6rem; font-weight: 400; color: var(--white); line-height: 1.4; margin-bottom: 1.5rem; }
  .opening-sub { font-size: 1rem; color: #888; line-height: 1.8; }

  /* Guarantee sections */
  .guarantee-section { padding: 4rem 0; background: var(--white); }
  .guarantee-section.alt { background: var(--light); }

  .section-label {
    margin-bottom: 2rem;
  }

  .section-label span {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--dark);
    padding: 0.5rem 1rem;
    display: inline-block;
  }

  .guarantee-grid {
    display: grid;
    gap: 1px;
    background: #e0e0e0;
  }

  .guarantee-grid.two-col {
    grid-template-columns: repeat(2, 1fr);
  }

  .guarantee-card {
    background: var(--white);
    padding: 2rem;
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 1.2rem;
    align-items: start;
    transition: background 0.2s;
  }

  .guarantee-section.alt .guarantee-card { background: var(--light); }
  .guarantee-card:hover { background: #eaeaea !important; }

  .guarantee-icon {
    font-size: 1.2rem;
    font-weight: 900;
    color: var(--red);
    padding-top: 0.15rem;
  }

  .guarantee-body h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--black);
    margin-bottom: 0.5rem;
  }

  .guarantee-body p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.7;
  }

  /* CTA */
  .cta-section { background: var(--red); padding: 4rem 0; }
  .cta-section h2 { font-family: var(--font-display); font-weight: 900; font-size: 2rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--white); margin-bottom: 1rem; }
  .cta-section p { font-size: 1rem; color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 2rem; max-width: 560px; }
  .btn-primary { display: inline-block; background: var(--white); color: var(--red); font-family: var(--font-display); font-weight: 700; font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.85rem 2.2rem; transition: all 0.2s; }
  .btn-primary:hover { background: var(--black); color: var(--white); }

  /* Footer */
  .footer { background: var(--black); color: var(--light); padding: 4rem 0 0; }
  .footer-grid { display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 4rem; padding-bottom: 3rem; border-bottom: 1px solid #2a2a2a; }
  .footer-col h5 { font-family: var(--font-display); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 1.2rem; }
  .footer-col address, .footer-col p { font-size: 0.9rem; color: #888; line-height: 1.8; }
  .footer-col a { color: #888; transition: color 0.2s; }
  .footer-col a:hover { color: var(--white); }
  .footer-col ul li { margin-bottom: 0.5rem; }
  .footer-bottom { padding: 1.2rem 0; }
  .footer-bottom p { font-family: var(--font-display); font-size: 0.8rem; letter-spacing: 0.05em; color: #444; text-align: center; }

  /* Responsive */
  @media (max-width: 900px) {
    .guarantee-grid.two-col { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .nav { display: none; }
  }
</style>