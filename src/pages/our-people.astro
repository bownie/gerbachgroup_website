---
// src/pages/our-people.astro
const title = "Our Leadership Team — Gerbach Logistics and Expedition Inc";
const description = "Meet the leadership team behind Gerbach Logistics and Expedition Inc.";

const leaders = [
  {
    name: "Maria Gerbach-Chen",
    title: "Chief Executive Officer",
    bio: "The great-niece of founders Heinrich and Wilhelm, Maria brings four decades of international logistics experience to her role. A graduate of Northwestern's Kellogg School of Management, she has led Gerbach's expansion into 47 countries while maintaining the personal touch that defines our service. Maria speaks five languages fluently and has been recognised by Logistics Weekly as one of the industry's most influential leaders for three consecutive years."
  },
  {
    name: "Matthew Bartholemew",
    title: "Chief Information Officer",
    bio: "A 15-year Gerbach veteran, Matthew began his career as a warehouse associate and worked his way up through every department before showing his acumen in leading our technology divisions. This unique perspective makes him incredibly effective at anticipating client needs and solving complex logistics challenges. Systems are the heart of what we do and Matthew is adept at leading us into the future."
  },
  {
    name: "Philip Coldwell",
    title: "Chief Operating Officer",
    bio: "With 22 years at Gerbach, Philip oversees our global operations with the precision of a master conductor. His background in supply chain optimisation and lean management has revolutionised our efficiency while preserving the quality that clients expect. Before joining Gerbach, Philip served as operations director for two Fortune 500 companies, bringing best practices from across industries."
  },
  {
    name: "David Kim",
    title: "Chief Financial Officer",
    bio: "With expertise spanning venture capital, corporate finance, and international markets, David ensures Gerbach's continued growth and stability. His strategic financial planning has funded our expansion into emerging markets while maintaining the competitive pricing our clients depend on."
  },
  {
    name: "Dr. Amelie Thierry",
    title: "Chief Technology Officer (Acting)",
    bio: "Amelie joined Gerbach five years ago after working in a series of startups following her studies at the Sorbonne, where she led groundbreaking research in predictive logistics algorithms. Under her leadership, Gerbach has become an industry pioneer in AI-driven route optimisation and predictive delivery systems. Her team's innovations have reduced delivery times by 23% while improving accuracy to 99.7%."
  },
  {
    name: "Elena Rodriguez",
    title: "Chief Sustainability Officer",
    bio: "Elena leads our commitment to environmental responsibility, developing programmes that have reduced our carbon footprint by 40% over the past three years. Her innovative partnerships with electric vehicle manufacturers and renewable energy providers are positioning Gerbach as the logistics leader for the next century."
  }
];
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div class="container">
    <span class="topbar-left">
      <a href="mailto:reachus@gerbachgroup.com">reachus@gerbachgroup.com</a>
      <span>Phone: +1 4700 555 555</span>
    </span>
    <a class="topbar-cta" href="/contact">Enquire Now</a>
  </div>
</div>

<!-- Header -->
<header class="header">
  <div class="container">
    <div class="logo">
      <a href="/">
        <span class="logo-main">GERBACH</span>
        <span class="logo-sub">Logistics &amp; Expedition Inc.</span>
      </a>
    </div>
    <nav class="nav">
      <ul>
        <li><a href="/our-story">Our Story</a></li>
        <li><a href="/our-people" class="active">Leadership</a></li>
        <li><a href="/global-reach">Global Reach</a></li>
        <li><a href="/advanced-systems">Advanced Systems</a></li>
        <li><a href="/our-promise">Our Promise</a></li>
        <li><a href="/our-guarantee">Our Guarantee</a></li>
      </ul>
    </nav>
  </div>
</header>

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-bg">
    <img src="/images/new-york-skyline-slice-1.jpg" alt="Gerbach leadership" />
    <div class="page-hero-overlay"></div>
  </div>
  <div class="container page-hero-content">
    <p class="eyebrow">Gerbach Logistics &amp; Expedition</p>
    <h1>Our Leadership Team</h1>
    <p class="subhead">The people behind every promise kept</p>
  </div>
</section>

<!-- Intro -->
<section class="intro-band">
  <div class="container">
    <p>Four generations of family leadership, augmented by the finest minds in global logistics. Our executive team combines decades of industry experience with an unwavering commitment to the values Heinrich and Wilhelm Gerbach established in 1934.</p>
  </div>
</section>

<!-- Leaders grid -->
<section class="leaders-section">
  <div class="container">
    <div class="leaders-grid">
      {leaders.map((leader, i) => (
        <div class={`leader-card ${i === 0 ? 'featured' : ''}`}>
          <div class="leader-initial">{leader.name.charAt(0)}</div>
          <div class="leader-info">
            <h2>{leader.name}</h2>
            <p class="leader-title">{leader.title}</p>
            <p class="leader-bio">{leader.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-col">
      <h5>Contact Info</h5>
      <address>
        4629 W Cermak Rd<br />
        Cicero, IL 60804<br />
        <a href="tel:+14700555555">+1 4700 555 555</a><br />
        <a href="mailto:reachus@gerbachgroup.com">reachus@gerbachgroup.com</a>
      </address>
    </div>
    <div class="footer-col">
      <h5>Navigation</h5>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/global-reach">Global Reach</a></li>
        <li><a href="/advanced-systems">Advanced Systems</a></li>
        <li><a href="/our-guarantee">Our Guarantee</a></li>
        <li><a href="/our-people">Leadership Team</a></li>
        <li><a href="/our-promise">Our Promise</a></li>
        <li><a href="/our-story">Our Story</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h5>About Us</h5>
      <p>Gerbach provides global transportation and expediting services for businesses of all sizes. A family-owned company from Cicero, IL with presence in the US, Europe, India, Africa, and Australasia.</p>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>© {new Date().getFullYear()} Gerbach Logistics and Expedition Inc. All Rights Reserved.</p>
    </div>
  </div>
</footer>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --red: #c8102e;
    --red-dark: #9e0c24;
    --black: #0d0d0d;
    --dark: #1a1a1a;
    --mid: #2e2e2e;
    --grey: #6b6b6b;
    --light: #f4f4f2;
    --white: #ffffff;
    --font-display: 'Barlow Condensed', sans-serif;
    --font-body: 'Barlow', sans-serif;
  }

  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: var(--font-body); background: var(--white); color: var(--black); line-height: 1.6; }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }
  address { font-style: normal; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  /* Top bar */
  .topbar { background: var(--black); color: var(--light); font-family: var(--font-display); font-size: 0.85rem; letter-spacing: 0.04em; padding: 0.5rem 0; }
  .topbar .container { display: flex; justify-content: space-between; align-items: center; }
  .topbar-left { display: flex; gap: 2rem; }
  .topbar-left a { color: #aaa; }
  .topbar-left a:hover { color: var(--white); }
  .topbar-cta { background: var(--red); color: var(--white); padding: 0.3rem 1rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; transition: background 0.2s; }
  .topbar-cta:hover { background: var(--red-dark); }

  /* Header */
  .header { background: var(--white); border-bottom: 3px solid var(--red); padding: 1.2rem 0; position: sticky; top: 0; z-index: 100; }
  .header .container { display: flex; justify-content: space-between; align-items: center; }
  .logo a { display: flex; flex-direction: column; line-height: 1; }
  .logo-main { font-family: var(--font-display); font-weight: 900; font-size: 2rem; letter-spacing: 0.08em; color: var(--black); }
  .logo-sub { font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--grey); }
  .nav ul { display: flex; gap: 2rem; }
  .nav a { font-family: var(--font-display); font-weight: 600; font-size: 0.85rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dark); transition: color 0.2s; }
  .nav a:hover, .nav a.active { color: var(--red); }

  /* Page hero */
  .page-hero { position: relative; height: 380px; overflow: hidden; display: flex; align-items: flex-end; }
  .page-hero-bg { position: absolute; inset: 0; }
  .page-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 60%, transparent 100%); }
  .page-hero-content { position: relative; z-index: 2; color: var(--white); padding-bottom: 3rem; }
  .eyebrow { font-family: var(--font-display); font-weight: 300; font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 0.5rem; }
  .page-hero-content h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(2.5rem, 5vw, 4rem); text-transform: uppercase; letter-spacing: 0.02em; line-height: 1; margin-bottom: 0.5rem; }
  .subhead { font-family: var(--font-display); font-weight: 300; font-size: 1.1rem; color: #ccc; letter-spacing: 0.05em; }

  /* Intro band */
  .intro-band { background: var(--dark); padding: 2.5rem 0; }
  .intro-band p { font-family: var(--font-display); font-size: 1.2rem; font-weight: 300; color: #aaa; line-height: 1.6; max-width: 800px; }

  /* Leaders */
  .leaders-section { padding: 5rem 0; }
  .leaders-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; background: #e8e8e8; }

  .leader-card {
    background: var(--white);
    padding: 2.5rem;
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1.5rem;
    align-items: start;
    transition: background 0.2s;
  }

  .leader-card:hover { background: var(--light); }

  .leader-card.featured {
    grid-column: 1 / -1;
    grid-template-columns: 80px 1fr;
    background: var(--dark);
    padding: 3rem;
  }

  .leader-initial {
    width: 60px;
    height: 60px;
    background: var(--red);
    color: var(--white);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .leader-card.featured .leader-initial {
    width: 80px;
    height: 80px;
    font-size: 2.5rem;
  }

  .leader-info h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--black);
    margin-bottom: 0.2rem;
  }

  .leader-card.featured .leader-info h2 { color: var(--white); font-size: 1.8rem; }

  .leader-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1rem;
  }

  .leader-bio {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.7;
  }

  .leader-card.featured .leader-bio { color: #aaa; }

  /* Footer */
  .footer { background: var(--black); color: var(--light); padding: 4rem 0 0; }
  .footer-grid { display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 4rem; padding-bottom: 3rem; border-bottom: 1px solid #2a2a2a; }
  .footer-col h5 { font-family: var(--font-display); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 1.2rem; }
  .footer-col address, .footer-col p { font-size: 0.9rem; color: #888; line-height: 1.8; }
  .footer-col a { color: #888; transition: color 0.2s; }
  .footer-col a:hover { color: var(--white); }
  .footer-col ul li { margin-bottom: 0.5rem; }
  .footer-col ul a { font-size: 0.9rem; }
  .footer-bottom { padding: 1.2rem 0; }
  .footer-bottom p { font-family: var(--font-display); font-size: 0.8rem; letter-spacing: 0.05em; color: #444; text-align: center; }

  /* Responsive */
  @media (max-width: 900px) {
    .leaders-grid { grid-template-columns: 1fr; }
    .leader-card.featured { grid-column: 1; }
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .nav { display: none; }
  }
</style>