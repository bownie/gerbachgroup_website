---
// src/pages/our-story.astro — refactored to use shared components
import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

// src/pages/our-people.astro
const title = "Our Leadership Team — Gerbach Logistics and Expedition Inc";
const description = "Meet the leadership team behind Gerbach Logistics and Expedition Inc.";

const leaders = [
  {
    name: "Maria Gerbach-Chen",
    title: "Chief Executive Officer",
    bio: "The great-niece of founders Heinrich and Wilhelm, Maria brings four decades of international logistics experience to her role. A graduate of Northwestern's Kellogg School of Management, she has led Gerbach's expansion into 47 countries while maintaining the personal touch that defines our service. Maria speaks five languages fluently and has been recognised by Logistics Weekly as one of the industry's most influential leaders for three consecutive years."
  },
  {
    name: "Matthew Bartholemew",
    title: "Chief Information Officer",
    bio: "A 15-year Gerbach veteran, Matthew began his career as a warehouse associate and worked his way up through every department before showing his acumen in leading our technology divisions. This unique perspective makes him incredibly effective at anticipating client needs and solving complex logistics challenges. Systems are the heart of what we do and Matthew is adept at leading us into the future."
  },
  {
    name: "Philip Coldwell",
    title: "Chief Operating Officer",
    bio: "With 22 years at Gerbach, Philip oversees our global operations with the precision of a master conductor. His background in supply chain optimisation and lean management has revolutionised our efficiency while preserving the quality that clients expect. Before joining Gerbach, Philip served as operations director for two Fortune 500 companies, bringing best practices from across industries."
  },
  {
    name: "David Kim",
    title: "Chief Financial Officer",
    bio: "With expertise spanning venture capital, corporate finance, and international markets, David ensures Gerbach's continued growth and stability. His strategic financial planning has funded our expansion into emerging markets while maintaining the competitive pricing our clients depend on."
  },
  {
    name: "Dr. Amelie Thierry",
    title: "Chief Technology Officer (Acting)",
    bio: "Amelie joined Gerbach five years ago after working in a series of startups following her studies at the Sorbonne, where she led groundbreaking research in predictive logistics algorithms. Under her leadership, Gerbach has become an industry pioneer in AI-driven route optimisation and predictive delivery systems. Her team's innovations have reduced delivery times by 23% while improving accuracy to 99.7%."
  },
  {
    name: "Elena Rodriguez",
    title: "Chief Sustainability Officer",
    bio: "Elena leads our commitment to environmental responsibility, developing programmes that have reduced our carbon footprint by 40% over the past three years. Her innovative partnerships with electric vehicle manufacturers and renewable energy providers are positioning Gerbach as the logistics leader for the next century."
  }
];
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body>

<TopBar />
<Header activePage="/our-people" />

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-bg">
    <img src="/images/new-york-skyline-slice-1.jpg" alt="Gerbach leadership" />
    <div class="page-hero-overlay"></div>
  </div>
  <div class="container page-hero-content">
    <p class="eyebrow">Gerbach Logistics &amp; Expedition</p>
    <h1>Our Leadership Team</h1>
    <p class="subhead">The people behind every promise kept</p>
  </div>
</section>

<!-- Intro -->
<section class="intro-band">
  <div class="container">
    <p>Four generations of family leadership, augmented by the finest minds in global logistics. Our executive team combines decades of industry experience with an unwavering commitment to the values Heinrich and Wilhelm Gerbach established in 1934.</p>
  </div>
</section>

<!-- Leaders grid -->
<section class="leaders-section">
  <div class="container">
    <div class="leaders-grid">
      {leaders.map((leader, i) => (
        <div class={`leader-card ${i === 0 ? 'featured' : ''}`}>
          <div class="leader-initial">{leader.name.charAt(0)}</div>
          <div class="leader-info">
            <h2>{leader.name}</h2>
            <p class="leader-title">{leader.title}</p>
            <p class="leader-bio">{leader.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<Footer />

</body>
</html>